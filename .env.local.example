# 로컬 관리자 + API (vercel dev)
# 이 파일을 복사해 `.env.local` 로 저장하세요. `.env.local` 은 Git에 올리지 마세요.

# --- 선택: localhost 에서만 OTP 생략 (admin-common.isAdminDevOtpBypass) ---
ADMIN_DEV_OTP_BYPASS=1

# --- 필수: 대시보드·회원·문의 API 데이터 ---
# localhost 는 코드상「알파/테스트 DB」로 취급되므로 _DEV(또는 공통 변수)를 쓰면 됩니다.
SUPABASE_URL_DEV=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY_DEV=your-service-role-key

# 단일 프로젝트만 쓸 때는 아래만 있어도 됩니다( 폴백 ).
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- ADMIN_DEV_OTP_BYPASS 를 쓰지 않을 때 필수 ---
# npm run admin:secrets 로 생성한 값을 넣을 수 있습니다.
# ADMIN_TOTP_SECRET=
# ADMIN_SESSION_SECRET=
